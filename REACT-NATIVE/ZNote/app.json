{
  "expo": {
    "name": "ZNote",
    "slug": "ZNote",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background1.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.zacksd3v.ZNote"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-image"
    ],
    "extra": {
      "eas": {
        "projectId": "6eabcb70-f5f0-4aa2-950d-216f0ace8ce3"
      }
    }
  }
}
